# ASV Finance backend environment — copy to .env on the server and fill real values.
# NEVER commit the real .env.

# Runtime connection: least-privilege app role (RLS is enforced on this role).
DATABASE_URL="postgresql://asvfinance_app:CHANGE_ME_APP@localhost:5432/asvfinance?schema=public"

# Migration connection: owner role (has DDL rights). Used only by prisma migrate.
MIGRATION_DATABASE_URL="postgresql://asvfinance_owner:CHANGE_ME_OWNER@localhost:5432/asvfinance?schema=public"

# JWT secrets — generate long random strings (e.g. `openssl rand -base64 48`).
JWT_ACCESS_SECRET="CHANGE_ME_ACCESS"
JWT_REFRESH_SECRET="CHANGE_ME_REFRESH"
JWT_ACCESS_TTL="30m"
JWT_REFRESH_TTL="7d"

# API
PORT=4001
NODE_ENV=development

# CORS: the web app origin(s), comma-separated.
CORS_ORIGINS="http://localhost:5173,https://asvsmallfinance.com"

# Where KYC images are stored (outside the git tree, backed up).
UPLOAD_DIR="./uploads"

# Idle session timeout shown to the client (minutes).
SESSION_IDLE_MINUTES=15
