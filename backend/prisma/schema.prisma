// ASV Finance — Prisma schema (foundation).
// Runtime uses DATABASE_URL (asvfinance_app, RLS-enforced).
// Migrations use directUrl = MIGRATION_DATABASE_URL (asvfinance_owner, DDL).
// Every tenant-scoped table has tenantId; RLS policies are applied by prisma/rls.sql
// (run via `npm run rls:apply` after migrate). See docs/ARCHITECTURE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("MIGRATION_DATABASE_URL")
}

enum Role {
  FDO // Field Officer  (employee portal)
  BM // Branch Manager (admin portal)
  HO // Head Office / company
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum ClientStatus {
  PENDING
  ACTIVE
  INACTIVE
  CLOSED
}

enum CenterStatus {
  ACTIVE
  INACTIVE
}

enum LoanApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoanStatus {
  OPEN
  CLOSED
}

// Which party a document type applies to (matches the reference's
// CLIENT/NOMINEE-tagged requirement list, e.g. "CLIENT PHOTO", "NOMINEE UID FRONT").
enum DocumentParty {
  CLIENT
  NOMINEE
  BOTH
}

// ---- Tenant (finance company) ---------------------------------------------
model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  code      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  // Admin-configurable (Masters > Settings): whether the FDO must pick a loan
  // product while enrolling a member, or it stays optional.
  requireLoanProductAtEnrollment Boolean  @default(false) @map("require_loan_product_at_enrollment")
  createdAt                      DateTime @default(now()) @map("created_at")
  updatedAt                      DateTime @updatedAt @map("updated_at")

  branches         Branch[]
  employees        Employee[]
  centers          Center[]
  groups           GroupUnit[]
  clients          Client[]
  coApplicants     CoApplicant[]
  frequencies      Frequency[]
  purposes         Purpose[]
  loanProducts     LoanProduct[]
  documentTypes    DocumentType[]
  kycDocuments     KycDocument[]
  kycNumbers       KycNumber[]
  loanApplications LoanApplication[]
  loans            Loan[]
  collections      Collection[]
  auditLogs        AuditLog[]
  eodClosings      EodClosing[]
  accessRoles      AccessRole[]

  @@map("tenant")
}

// ---- Access role (permission set) ------------------------------------------
// A named checklist of ACTION permissions, assigned to employees. Independent of
// the Role enum below, which is the data-visibility Access Level (FDO/BM/HO).
model AccessRole {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  permissions String[] @default([]) // permission keys, validated against the catalog
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("access_role")
}

// ---- Branch ----------------------------------------------------------------
model Branch {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String
  name        String
  workingDate DateTime @default(now()) @map("working_date") @db.Date
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  employees   Employee[]
  centers     Center[]
  eodClosings EodClosing[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branch")
}

// ---- Employee (FDO / BM / HO) ----------------------------------------------
model Employee {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  branchId     String?        @map("branch_id") @db.Uuid
  code         String // e.g. "45" (FDO code) or "BM-NATHAM"
  name         String
  login        String         @unique
  passwordHash String         @map("password_hash")
  role         Role // Access Level: data visibility scope (FDO/BM/HO) + portal
  accessRoleId String?        @map("access_role_id") @db.Uuid
  status       EmployeeStatus @default(ACTIVE)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  branch     Branch?          @relation(fields: [branchId], references: [id])
  accessRole AccessRole?      @relation(fields: [accessRoleId], references: [id])
  centers    EmployeeCenter[]
  managing   Center[]         @relation("CenterFdo")

  @@index([tenantId])
  @@map("employee")
}

// ---- Center ----------------------------------------------------------------
model Center {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  branchId      String       @map("branch_id") @db.Uuid
  fdoId         String?      @map("fdo_id") @db.Uuid
  code          String // e.g. "029"
  name          String
  address       String?
  meetingDay    String?      @map("meeting_day") // MON..SUN
  meetingTime   String?      @map("meeting_time")
  meetingPlace  String?      @map("meeting_place")
  formationDate DateTime?    @map("formation_date") @db.Date
  nextMeeting   DateTime?    @map("next_meeting_date") @db.Date
  mobile        String?
  latitude      Decimal?     @db.Decimal(10, 7)
  longitude     Decimal?     @db.Decimal(10, 7)
  status        CenterStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  branch    Branch           @relation(fields: [branchId], references: [id])
  fdo       Employee?        @relation("CenterFdo", fields: [fdoId], references: [id])
  groups    GroupUnit[]
  clients   Client[]
  employees EmployeeCenter[]

  @@unique([tenantId, code])
  @@index([tenantId, branchId])
  @@map("center")
}

// ---- Employee ⇄ Center assignment (many-to-many) ---------------------------
model EmployeeCenter {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  centerId   String   @map("center_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])
  center   Center   @relation(fields: [centerId], references: [id])

  @@unique([employeeId, centerId])
  @@index([tenantId])
  @@map("employee_center")
}

// ---- Group (5 per center) --------------------------------------------------
model GroupUnit {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  centerId  String   @map("center_id") @db.Uuid
  groupNo   Int      @map("group_no") // 1..5
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  center  Center   @relation(fields: [centerId], references: [id])
  clients Client[]

  @@unique([centerId, groupNo])
  @@index([tenantId])
  @@map("group_unit")
}

// ---- Client (member) -------------------------------------------------------
model Client {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  centerId       String       @map("center_id") @db.Uuid
  groupId        String       @map("group_id") @db.Uuid
  memberNo       Int          @map("member_no") // 1..5
  clientCode     String       @unique @map("client_code") // e.g. PMF005179
  name           String
  dob            DateTime?    @db.Date
  gender         String?
  mobile         String?
  presentAddress String?      @map("present_address")
  pincode        String?
  district       String?
  state          String?
  monthlyIncome  Decimal?     @map("monthly_income") @db.Decimal(14, 2)
  monthlyExpense Decimal?     @map("monthly_expense") @db.Decimal(14, 2)
  fatherName     String?      @map("father_name")
  latitude       Decimal?     @db.Decimal(10, 7)
  longitude      Decimal?     @db.Decimal(10, 7)
  dateOfJoining     DateTime?    @map("date_of_joining") @db.Date
  status            ClientStatus @default(PENDING)
  isActive          Boolean      @default(true) @map("is_active")
  // Optional loan-product + purpose preference captured at enrollment
  // (informational — NOT a LoanApplication; the formal application step,
  // with its own eligibility gate, happens later).
  requestedProductId String?     @map("requested_product_id") @db.Uuid
  requestedPurposeId String?     @map("requested_purpose_id") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  center           Center            @relation(fields: [centerId], references: [id])
  group            GroupUnit         @relation(fields: [groupId], references: [id])
  requestedProduct LoanProduct?      @relation(fields: [requestedProductId], references: [id])
  requestedPurpose Purpose?          @relation(fields: [requestedPurposeId], references: [id])
  coApplicant      CoApplicant?
  documents        KycDocument[]
  kycNumbers       KycNumber[]
  applications     LoanApplication[]
  loans            Loan[]

  @@index([tenantId, centerId])
  @@map("client")
}

// ---- Co-Applicant / Nominee — 1:1 with Client ------------------------------
// ID-number fields (voter/PAN/etc.) live in KycNumber (party=NOMINEE), driven
// by the same admin-managed DocumentType master as the client's own numbers.
model CoApplicant {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  clientId  String    @unique @map("client_id") @db.Uuid
  name      String
  gender    String?
  dob       DateTime? @db.Date
  relation  String?   @map("relation_with_client")
  mobile    String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@index([tenantId])
  @@map("co_applicant")
}

// ---- Masters ----------------------------------------------------------------

// Repayment frequency (DLY/WKS/MNS/MON) — drives schedule spacing.
model Frequency {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String // DLY | WKS | MNS | MON
  name        String
  daysBetween Int      @map("days_between")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  loanProducts LoanProduct[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("frequency")
}

// Loan purpose (livelihood activity) — large, searchable list.
model Purpose {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  loanApplications   LoanApplication[]
  requestedByClients Client[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("purpose")
}

// A named loan product tier. Each tier has FIXED totals (not a % rate formula) —
// e.g. "100000 LOAN 102 DUE" = amount 100000, 102 weekly dues, interest 42800.
// Per-installment split is even: principal = loanAmount/totalDues,
// interest = interestAmount/totalDues (confirmed with the client; see
// backend/src/loans/schedule.util.ts).
model LoanProduct {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  frequencyId    String   @map("frequency_id") @db.Uuid
  name           String
  loanAmount     Decimal  @map("loan_amount") @db.Decimal(14, 2)
  totalDues      Int      @map("total_dues")
  interestAmount Decimal  @map("interest_amount") @db.Decimal(14, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  frequency          Frequency         @relation(fields: [frequencyId], references: [id])
  loanApplications   LoanApplication[]
  loans              Loan[]
  requestedByClients Client[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("loan_product")
}

// Required KYC document types, tagged to CLIENT / NOMINEE / BOTH — drives the
// eligibility-gate "X Image Not Uploaded" / "X Number Not Entered" warnings.
//
// Single admin-managed source of truth for an ID proof, per party (CLIENT/
// NOMINEE/BOTH): whether it needs a typed number (KycNumber), a photo upload
// (KycDocument), and whether that requirement is mandatory. E.g. "PAN Card"
// might be requiresNumber=true, requiresPhoto=false; "Passbook" the reverse.
model DocumentType {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  name           String // e.g. "Aadhaar Card", "PAN Card", "Passbook"
  appliesTo      DocumentParty @default(BOTH) @map("applies_to")
  requiresNumber Boolean       @default(true) @map("requires_number")
  requiresPhoto  Boolean       @default(true) @map("requires_photo")
  maskValue      Boolean       @default(false) @map("mask_value") // e.g. Aadhaar
  isMandatory    Boolean       @default(true) @map("is_mandatory")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  documents KycDocument[]
  numbers   KycNumber[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("document_type")
}

// An uploaded KYC document image for a client (or their nominee).
model KycDocument {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  clientId       String        @map("client_id") @db.Uuid
  documentTypeId String        @map("document_type_id") @db.Uuid
  party          DocumentParty @default(CLIENT)
  filePath       String?       @map("file_path")
  mimeType       String?       @map("mime_type")
  originalName   String?       @map("original_name")
  uploadedAt     DateTime      @default(now()) @map("uploaded_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])
  documentType DocumentType @relation(fields: [documentTypeId], references: [id])

  @@unique([clientId, documentTypeId, party])
  @@index([tenantId, clientId])
  @@map("kyc_document")
}

// A typed ID-proof number for a client (or their nominee), e.g. Aadhaar/Voter/
// PAN. Dynamic and admin-driven via DocumentType, mirroring KycDocument —
// replaces the old fixed Kyc/CoApplicant number columns.
model KycNumber {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  clientId       String        @map("client_id") @db.Uuid
  documentTypeId String        @map("document_type_id") @db.Uuid
  party          DocumentParty @default(CLIENT)
  value          String
  updatedAt      DateTime      @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])
  documentType DocumentType @relation(fields: [documentTypeId], references: [id])

  @@unique([clientId, documentTypeId, party])
  @@index([tenantId, clientId])
  @@map("kyc_number")
}

// ---- Loan application (employee submits; BM approves+disburses later) -----
model LoanApplication {
  id               String                @id @default(uuid()) @db.Uuid
  tenantId         String                @map("tenant_id") @db.Uuid
  clientId         String                @map("client_id") @db.Uuid
  productId        String                @map("product_id") @db.Uuid
  purposeId        String                @map("purpose_id") @db.Uuid
  requestedAmount  Decimal               @map("requested_amount") @db.Decimal(14, 2)
  sanctionedAmount Decimal?              @map("sanctioned_amount") @db.Decimal(14, 2)
  status           LoanApplicationStatus @default(PENDING)
  warnings         Json? // eligibility warnings captured at submission time
  createdBy        String?               @map("created_by") @db.Uuid
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  tenant  Tenant      @relation(fields: [tenantId], references: [id])
  client  Client      @relation(fields: [clientId], references: [id])
  product LoanProduct @relation(fields: [productId], references: [id])
  purpose Purpose     @relation(fields: [purposeId], references: [id])
  loan    Loan?

  @@index([tenantId, clientId])
  @@map("loan_application")
}

// A disbursed loan. Created later by the BM disbursement action (maker-checker);
// the employee portal only ever reads these (existing-loan panel, ledger).
model Loan {
  id             String     @id @default(uuid()) @db.Uuid
  tenantId       String     @map("tenant_id") @db.Uuid
  clientId       String     @map("client_id") @db.Uuid
  applicationId  String?    @unique @map("application_id") @db.Uuid
  productId      String     @map("product_id") @db.Uuid
  loanAccount    String     @unique @map("loan_account") // e.g. PMF005179/2
  cycleNo        Int        @map("cycle_no")
  loanAmount     Decimal    @map("loan_amount") @db.Decimal(14, 2)
  interestAmount Decimal    @map("interest_amount") @db.Decimal(14, 2)
  totalAmount    Decimal    @map("total_amount") @db.Decimal(14, 2)
  totalDues      Int        @map("total_dues")
  disbursalDate  DateTime   @map("disbursal_date") @db.Date
  dueStartDate   DateTime   @map("due_start_date") @db.Date
  maturityDate   DateTime   @map("maturity_date") @db.Date
  closedDate     DateTime?  @map("closed_date") @db.Date
  loanType       LoanStatus @default(OPEN) @map("loan_type")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  client      Client              @relation(fields: [clientId], references: [id])
  product     LoanProduct         @relation(fields: [productId], references: [id])
  application LoanApplication?    @relation(fields: [applicationId], references: [id])
  schedule    RepaymentSchedule[]
  collections Collection[]

  @@index([tenantId, clientId])
  @@map("loan")
}

// One row per installment: planned (due) vs actual (collected). The coll*
// columns are a CACHE — the sum of this row's Collection entries — kept for
// fast reads; Collection is the append-only source of truth / audit trail.
model RepaymentSchedule {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  loanId      String       @map("loan_id") @db.Uuid
  loan        Loan         @relation(fields: [loanId], references: [id])
  dueNo       Int          @map("due_no")
  dueDate     DateTime     @map("due_date") @db.Date
  duePri      Decimal      @map("due_pri") @db.Decimal(14, 2)
  dueInt      Decimal      @map("due_int") @db.Decimal(14, 2)
  dueAmt      Decimal      @map("due_amt") @db.Decimal(14, 2)
  collDate    DateTime?    @map("coll_date") @db.Date
  collPri     Decimal      @default(0) @map("coll_pri") @db.Decimal(14, 2)
  collInt     Decimal      @default(0) @map("coll_int") @db.Decimal(14, 2)
  collAmt     Decimal      @default(0) @map("coll_amt") @db.Decimal(14, 2)
  dueBalance  Decimal      @map("due_balance") @db.Decimal(14, 2)
  collections Collection[]

  @@unique([loanId, dueNo])
  @@index([tenantId, loanId])
  @@map("repayment_schedule")
}

// ---- Collection (append-only transaction log) ------------------------------
// Every collection event posted by an FDO. Never edited or deleted; the
// RepaymentSchedule cache columns are recomputed from the sum of these rows.
// This IS the audit trail for money collected (invariant #5).
model Collection {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  loanId      String   @map("loan_id") @db.Uuid
  scheduleId  String   @map("schedule_id") @db.Uuid
  collectedOn DateTime @map("collected_on") @db.Date // branch working_date at time of entry
  amount      Decimal  @db.Decimal(14, 2)
  pri         Decimal  @db.Decimal(14, 2)
  int         Decimal  @db.Decimal(14, 2)
  enteredBy   String   @map("entered_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  loan     Loan              @relation(fields: [loanId], references: [id])
  schedule RepaymentSchedule @relation(fields: [scheduleId], references: [id])

  @@index([tenantId, loanId])
  @@index([tenantId, scheduleId])
  @@map("collection")
}

// ---- Audit log (generic, money-affecting actions) --------------------------
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  entity     String // e.g. "Loan", "Collection", "LoanApplication"
  entityId   String   @map("entity_id") @db.Uuid
  action     String // e.g. "DISBURSE", "COLLECT", "REJECT"
  employeeId String   @map("employee_id") @db.Uuid
  before     Json?
  after      Json?
  at         DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entity, entityId])
  @@map("audit_log")
}

// ---- End of Day cash reconciliation ----------------------------------------
// One row = one branch's closed working day. Closing a day snapshots the cash
// position (opening + receipts − payments = closing) and advances the
// branch's working_date to the next day — the single place that date moves
// forward (invariant #4: everything else reads working_date, never now()).
model EodClosing {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  eodDate        DateTime @map("eod_date") @db.Date // the working_date that was closed
  openingBalance Decimal  @map("opening_balance") @db.Decimal(14, 2)
  totalReceipts  Decimal  @map("total_receipts") @db.Decimal(14, 2)
  totalPayments  Decimal  @map("total_payments") @db.Decimal(14, 2)
  closingBalance Decimal  @map("closing_balance") @db.Decimal(14, 2)
  doneBy         String   @map("done_by") @db.Uuid
  doneAt         DateTime @default(now()) @map("done_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, eodDate])
  @@index([tenantId, branchId])
  @@map("eod_closing")
}
