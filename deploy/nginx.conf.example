# ASV Finance — nginx site config (example).
# Place at /etc/nginx/sites-available/asvsmallfinance.com and symlink to sites-enabled.
# Serves the React build and reverse-proxies the API. Run certbot for HTTPS after.

server {
    server_name asvsmallfinance.com www.asvsmallfinance.com;

    # --- React SPA (built assets) ---
    root /var/www/asv_finance_webapp/frontend/dist;
    index index.html;

    # SPA history fallback: /login, /admin, /app/* all resolve to index.html.
    # index.html must NOT be cached — it references content-hashed assets, so a
    # stale copy would keep loading old JS/CSS and users never get updates.
    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-cache";
    }

    # --- API reverse proxy ---
    location /api/ {
        proxy_pass http://127.0.0.1:4001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Cache built static assets aggressively (they are content-hashed by Vite).
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    listen 80;
    # After `certbot --nginx -d asvsmallfinance.com -d www.asvsmallfinance.com`,
    # certbot adds the listen 443 / ssl_certificate lines here.
}
